{

	"Ans.Net10.Web": {

		"DefaultLayout": "", // Required!
		"DefaultContainerClasses": "",

		"Culture": "ru",
		"SystemToken": "",
		"SystemLayout": "",
		"UseRuntimeCompilation": true,
		"UseDeveloperMode": false,
		"UseSessions": true,
		"CorsProfile": "",

		"Swagger": [ "name-v1|Name API V1" ],

		"Mimetypes": [
			".7z|application/zip",
			".apk|application/vnd.android.package-archive",
			".cer|application/pkix-cert",
			".grid|text/plain",
			".sig|application/pgp-signature"
		],

		"Routes": [ "name|template|controller|action" ],

		"Errors": {
			"Layout": "",
			"ServerErrorPath": "",
			"HttpErrorPath": "",
			"ShowInfo": true,
			"Picture400": "",
			"Picture403": "",
			"Picture404": "",
			"Picture500": ""
		},

		"MailService": {
			"SmtpServer": "",
			"SmtpPort": 465, // 587,
			"SmtpUseSsl": true, // false,
			"SmtpUsername": "",
			"SmtpPassword": "",
			"DefaultFromAddress": "",
			"DefaultFromTitle": ""
		},

		"Subnets": {
			"Admin": "000.000.000.000/00;000.000.000.000/00",
			"Safe": "000.000.000.000/00;000.000.000.000/00",
			"Unsafe": "000.000.000.000/00;000.000.000.000/00",
			"Allow": "000.000.000.000/00;000.000.000.000/00",
			"Deny": "000.000.000.000/00;000.000.000.000/00"
		}

	},



	"NLog": {
		"autoReload": true,
		"throwConfigExceptions": true,
		"internalLogLevel": "Info",
		"internalLogFile": "C:/temp/internal-nlog.txt",
		"extensions": [ { "assembly": "NLog.Web.AspNetCore" } ],
		"variables": {
			"varApp": "AppName",
			"varDirectory": "C:/inetpub/wwwroot/_LOGS/${varApp}/${date:format=yyyy-0MM}",
			"varFile": "${varDirectory}/${level}_${date:format=yyyy-0MM-dd_HH}.log"
		},
		"default-wrapper": {
			"type": "AsyncWrapper",
			"overflowAction": "Block"
		},
		"targets": {
			"all-file": {
				"type": "File",
				"fileName": "${varFile}"
			}
		},
		"rules": [
			{
				"logger": "*",
				"minLevel": "Warn",
				"writeTo": "all-file"
			}
		]
	},



	"Logging": {
		"LogLevel": { "Default": "Debug" },
		"NLog": {
			"IncludeScopes": true,
			"RemoveLoggerFactoryFilter": true
		}
	},



	"AllowedHosts": "*"

}